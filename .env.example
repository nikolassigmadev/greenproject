# If unset, falls back to a mailto: link to VITE_DISPUTE_EMAIL.
VITE_DISPUTE_ENDPOINT=
VITE_DISPUTE_EMAIL=disputes@ethicalshopper.app

# Backend Configuration
OPENAI_API_KEY=your_openai_api_key_here
PORT=3001
CLIENT_URL=http://localhost:5173
