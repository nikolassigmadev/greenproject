# Frontend Configuration
VITE_BACKEND_URL=http://localhost:3001

# Dispute / correction workflow
# The frontend POSTs disputes to {VITE_BACKEND_URL}/api/disputes automatically.
# Override with VITE_DISPUTE_ENDPOINT to use a different endpoint.
# If both backend and endpoint are unreachable, falls back to mailto.
VITE_DISPUTE_ENDPOINT=
VITE_DISPUTE_EMAIL=disputes@ethicalshopper.app

# Backend Configuration
OPENAI_API_KEY=your_openai_api_key_here
PORT=3001
CLIENT_URL=http://localhost:5173
