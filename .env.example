# Frontend Configuration
VITE_BACKEND_URL=http://localhost:3001

# Backend Configuration
OPENAI_API_KEY=your_openai_api_key_here
PORT=3001
CLIENT_URL=http://localhost:5173

# Product image search (optional). SerpAPI key powering /api/product-image —
# fetches a real, white-background catalog photo of the scanned product from
# Google Images to show on the verdict screen. Get one at https://serpapi.com.
# Leave unset to disable — the verdict falls back to the Open Food Facts cover.
SERPAPI_KEY=your_serpapi_key_here

# Postgres scan log (optional). Set to a Supabase/Neon/Railway connection string
# to record every AI analysis (full response + metadata) to the ai_scans table.
# Leave unset to disable — the server runs fine without it.
# Supabase: Project Settings → Database → Connection string → URI (port 5432).
DATABASE_URL=
# Set to "false" only if connecting to a local Postgres without TLS.
# DATABASE_SSL=false
